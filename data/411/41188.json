{"date":"2012-05-25","platform":"TV","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/c0/28/41188_dD7DH.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/c0/28/41188_dD7DH.jpg","large":"https://lain.bgm.tv/pic/cover/l/c0/28/41188_dD7DH.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/c0/28/41188_dD7DH.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/c0/28/41188_dD7DH.jpg"},"summary":"      2026年，地球环境恶化，人类陷入重大生态危机。林业局、国土资源局等相关部门高度重视，领导干部积极应对，接上级指示，环保基地决定挑选一批优秀成员组成飞龙环保队，调查地球环境危机的原因，并寻找方法阻止环境进一步恶化。队伍由五位年轻人组成：队长炽焰、智囊深蓝、体育高手阿泰、少女小欣和电脑天才小星。他们历经千难万险，阻止了幕后黑手--邪恶科学家“魔尊”的阴谋，使生态环境恢复了正常。地球回复往日的平静，飞龙环保队员们回到基地，继续为保卫地球生态环境而努力。","name":"钢铁飞龙","name_cn":"钢铁飞龙","tags":[{"name":"国产","count":33,"total_cont":0},{"name":"3D","count":15,"total_cont":0},{"name":"科幻","count":14,"total_cont":0},{"name":"童年","count":14,"total_cont":0},{"name":"原创","count":9,"total_cont":0},{"name":"中国","count":8,"total_cont":0},{"name":"蓝狐","count":8,"total_cont":0},{"name":"TV","count":7,"total_cont":0},{"name":"特摄","count":7,"total_cont":0},{"name":"2012","count":6,"total_cont":0},{"name":"国产动画","count":5,"total_cont":0},{"name":"蓝弧","count":4,"total_cont":0},{"name":"机战","count":4,"total_cont":0},{"name":"机甲","count":3,"total_cont":0},{"name":"子供向","count":2,"total_cont":0},{"name":"动画","count":2,"total_cont":0},{"name":"战斗","count":2,"total_cont":0},{"name":"国动","count":1,"total_cont":0},{"name":"中学","count":1,"total_cont":0},{"name":"一代神作","count":1,"total_cont":0},{"name":"蓝弧文化","count":1,"total_cont":0},{"name":"南方少儿频道","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"钢铁飞龙"},{"key":"话数","value":"52"},{"key":"放送开始","value":"2012年5月25日"},{"key":"其他电视台","value":"浙江少儿、卡酷卫视"},{"key":"导演","value":"王巍"},{"key":"每集时长","value":"25min"},{"key":"脚本","value":"王巍"}],"rating":{"rank":5435,"total":52,"count":{"1":0,"2":1,"3":2,"4":4,"5":13,"6":14,"7":13,"8":3,"9":0,"10":2},"score":5.9},"total_episodes":52,"collection":{"on_hold":6,"dropped":18,"wish":14,"collect":124,"doing":4},"id":41188,