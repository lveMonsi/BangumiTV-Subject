{"date":"2024-07-21","platform":"WEB","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/76/39/501710_o8RC3.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/76/39/501710_o8RC3.jpg","large":"https://lain.bgm.tv/pic/cover/l/76/39/501710_o8RC3.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/76/39/501710_o8RC3.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/76/39/501710_o8RC3.jpg"},"summary":"《茶啊二中第五季》讲述了在东北校园里一群性格迥异、顽皮叛逆又可爱自强的中学生与老师、家长们发生的一系列笑料百出的校园故事。挥手作别初二的青涩时光，王强携手三班小伙伴们，在全新的环境中迎接他们欢声笑语的初三生活，除了深厚的友情和师生情，一切都是崭新的，生机勃勃，充满了未知也充满了希望。他们在一起或欢笑，或争吵，或互助，大家在每一次啼笑皆非的小事中不断成长，收获着属于自己那份热烈又勇敢的闪耀青春。故事密集的笑点让观众捧腹大笑的同时，通过呈现中学时代美好难忘的生活，引发对于国产青春的回忆与强烈共鸣。","name":"茶啊二中第五季","name_cn":"","tags":[{"name":"国产","count":25,"total_cont":0},{"name":"校园","count":22,"total_cont":0},{"name":"搞笑","count":15,"total_cont":0},{"name":"青春","count":13,"total_cont":0},{"name":"中国","count":11,"total_cont":0},{"name":"原创","count":10,"total_cont":0},{"name":"2024","count":9,"total_cont":0},{"name":"WEB","count":8,"total_cont":0},{"name":"动画","count":6,"total_cont":0},{"name":"原创动画","count":4,"total_cont":0},{"name":"茶啊二中","count":3,"total_cont":0},{"name":"国创","count":3,"total_cont":0},{"name":"国漫","count":1,"total_cont":0},{"name":"泡面番","count":1,"total_cont":0},{"name":"TV","count":1,"total_cont":0},{"name":"腾讯","count":1,"total_cont":0},{"name":"2024年7月","count":1,"total_cont":0},{"name":"喜剧","count":1,"total_cont":0},{"name":"中8","count":1,"total_cont":0},{"name":"剧情在线，远远高出预期","count":1,"total_cont":0}],"infobox":[{"key":"别名","value":[{"v":"茶啊二中 第5季"}]},{"key":"话数","value":"8"},{"key":"放送开始","value":"2024年7月21日"},{"key":"放送星期","value":"星期日"},{"key":"导演","value":"夏铭泽"},{"key":"音乐","value":"杨芮、松田彬人"},{"key":"製作","value":"凝羽动画、腾讯视频；出品人：邢原源、孙忠怀"},{"key":"监制","value":"总监制：邢原源、马延琨；刘佳靓"},{"key":"企画","value":"总策划：邢原源、崔超"},{"key":"制片人","value":"姜峰、连沁雨"},{"key":"美术监督","value":"陈小龙（美术总监）"},{"key":"制作总监","value":"郭红进"},{"key":"资产总监","value":"王洪良"},{"key":"绑定总监","value":"刘炫麟"},{"key":"动画总监","value":